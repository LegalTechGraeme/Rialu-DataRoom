# Copy to server/.env and set your key (never commit .env)

# Groq API key — required for AI document analysis and legal assistant
# Get one at https://console.groq.com/
GROQ_API_KEY=

# Model used for document analysis and chat (Groq-hosted Llama)
GROQ_MODEL=llama-3.3-70b-versatile

# Delay between batch analyses in ms (12000 recommended for free tier rate limits)
GROQ_ANALYZE_DELAY_MS=12000

# API server port (default 3001)
# PORT=3001
